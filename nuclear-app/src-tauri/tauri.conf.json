{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nuclear Downloader",
  "version": "0.4.1",
  "identifier": "com.mrw.nuclear",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Nuclear Downloader",
        "width": 1000,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "base-uri": "'self'",
        "connect-src": ["'self'", "ipc:", "http://ipc.localhost", "https://ipc.localhost"],
        "font-src": ["'self'", "data:"],
        "form-action": "'self'",
        "frame-ancestors": "'none'",
        "img-src": ["'self'", "https:"],
        "object-src": "'none'",
        "script-src": "'self'",
        "style-src": ["'self'", "'unsafe-inline'"]
      },
      "devCsp": {
        "default-src": "'self'",
        "base-uri": "'self'",
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "https://ipc.localhost",
          "http://localhost:*",
          "http://127.0.0.1:*",
          "ws://localhost:*",
          "ws://127.0.0.1:*"
        ],
        "font-src": ["'self'", "data:"],
        "form-action": "'self'",
        "frame-ancestors": "'none'",
        "img-src": ["'self'", "https:", "http://localhost:*", "http://127.0.0.1:*"],
        "object-src": "'none'",
        "script-src": ["'self'", "http://localhost:*", "http://127.0.0.1:*"],
        "style-src": ["'self'", "'unsafe-inline'", "http://localhost:*", "http://127.0.0.1:*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ]
  }
}
